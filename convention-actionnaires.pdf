:root{
  --blue:#174a7e;--blue2:#2468a6;--light:#f4f7fb;--white:#fff;--text:#17233a;
  --muted:#718096;--green:#2e9b67;--orange:#f0a14a;--red:#d9534f;--purple:#6d4fc2;
  --border:#e4eaf2;--shadow:0 14px 40px rgba(23,74,126,.10);--radius:18px;
}
*{box-sizing:border-box}body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:var(--light);color:var(--text)}
button,input,select,textarea{font:inherit}.app{display:grid;grid-template-columns:265px 1fr;min-height:100vh}
.sidebar{background:linear-gradient(180deg,#123d69,#1a568d);color:#fff;padding:24px 18px;position:sticky;top:0;height:100vh}
.brand{display:flex;gap:12px;align-items:flex-start;padding:0 8px;margin-bottom:30px}.logo{width:48px;height:48px;border-radius:14px;background:#fff;color:var(--blue);display:flex;align-items:center;justify-content:center;font-weight:900;box-shadow:0 8px 24px rgba(0,0,0,.15)}
.brand h1{font-size:21px;margin:1px 0 4px;letter-spacing:.5px}.brand small{display:block;opacity:.78;line-height:1.35;font-size:11px;max-width:165px}
nav{display:flex;flex-direction:column;gap:10px}.nav-btn{border:0;background:transparent;color:#dceaff;padding:14px;border-radius:13px;text-align:left;font-weight:700;cursor:pointer;display:flex;gap:12px;align-items:center}.nav-btn:hover,.nav-btn.active{background:rgba(255,255,255,.14);color:#fff}
.sidebar-note{position:absolute;left:18px;right:18px;bottom:18px;padding:14px;border-radius:14px;background:rgba(255,255,255,.08);font-size:12px;line-height:1.5}
.main{padding:30px 32px 46px;overflow:hidden}.topbar{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px}.topbar h2{margin:0;font-size:29px}.topbar p{margin:7px 0 0;color:var(--muted)}
.view{display:none}.view.active{display:block}.grid{display:grid;gap:18px}.stats{grid-template-columns:repeat(4,minmax(0,1fr));margin-bottom:20px}.card{background:#fff;border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow)}
.stat{padding:21px;position:relative;overflow:hidden}.stat:after{content:"";position:absolute;width:92px;height:92px;border-radius:50%;right:-30px;top:-30px;background:rgba(36,104,166,.08)}.stat .label{color:var(--muted);font-size:13px;font-weight:800}.stat .value{font-size:31px;font-weight:900;margin:10px 0 4px}.stat .meta{font-size:12px;color:var(--green)}
.two-col{grid-template-columns:1.3fr .7fr}.panel{padding:20px}.panel-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:14px}.panel-head h3{margin:0;font-size:18px}.muted{color:var(--muted)}
.call-box{padding:24px;background:linear-gradient(135deg,#174a7e,#2b73ad);color:#fff;border-radius:18px}.call-box h3{font-size:21px;margin:0 0 8px}.call-box p{margin:0 0 16px;opacity:.88;line-height:1.5}.call-meta{display:flex;gap:12px;flex-wrap:wrap}.call-chip{background:rgba(255,255,255,.14);padding:9px 12px;border-radius:999px;font-size:12px;font-weight:700}
.project{margin:15px 0}.project-row{display:flex;justify-content:space-between;font-size:13px;margin-bottom:7px}.progress{height:9px;background:#edf1f6;border-radius:999px;overflow:hidden}.progress span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,var(--blue2),var(--purple))}
.btn{border:0;border-radius:12px;padding:11px 16px;font-weight:800;cursor:pointer}.btn-primary{background:var(--blue);color:#fff}.btn-light{background:#fff;color:var(--blue);border:1px solid var(--border)}.btn-green{background:var(--green);color:#fff}.btn-danger{background:var(--red);color:#fff}
.profile-card{padding:24px;display:grid;grid-template-columns:auto 1fr auto;gap:18px;align-items:center}.avatar{width:74px;height:74px;border-radius:22px;background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:900}.profile-card h3{margin:0 0 4px}.profile-card p{margin:4px 0;color:var(--muted)}
.summary-grid{grid-template-columns:repeat(3,1fr);margin-top:18px}.mini{padding:18px}.mini strong{display:block;font-size:23px;margin-top:6px}.section-block{margin-top:18px}
table{width:100%;border-collapse:collapse}th,td{padding:12px 10px;border-bottom:1px solid var(--border);font-size:13px;text-align:left;vertical-align:middle}th{background:#fafcff;color:var(--muted);font-weight:800}tr:hover td{background:#fbfdff}.table-wrap{overflow:auto}
.badge{display:inline-flex;padding:6px 9px;border-radius:999px;font-size:11px;font-weight:800}.ok{background:#e6f6ef;color:#207d54}.warn{background:#fff3df;color:#b66c13}.bad{background:#fdeaea;color:#b53838}.info{background:#e9f1fb;color:#2e65a1}
.direction-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}.subtab{border:1px solid var(--border);background:#fff;color:var(--blue);padding:10px 14px;border-radius:11px;font-weight:800;cursor:pointer}.subtab.active{background:var(--blue);color:#fff}.subview{display:none}.subview.active{display:block}
.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}.search,.filter{background:#fff;border:1px solid var(--border);border-radius:12px;padding:11px 13px}.search{flex:1;min-width:230px}.doc-grid{grid-template-columns:repeat(3,1fr)}.doc{padding:18px}.doc-icon{width:42px;height:42px;border-radius:12px;background:#eef4fb;color:var(--blue);display:flex;align-items:center;justify-content:center;font-weight:900;margin-bottom:12px}.doc h4{margin:0 0 6px}.doc p{font-size:12px;color:var(--muted);min-height:36px}
.modal{position:fixed;inset:0;background:rgba(12,25,45,.55);display:none;align-items:center;justify-content:center;padding:20px;z-index:20}.modal.open{display:flex}.modal-card{background:#fff;border-radius:20px;max-width:760px;width:100%;max-height:90vh;overflow:auto;padding:24px;box-shadow:0 30px 80px rgba(0,0,0,.3)}.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}.close{border:0;background:#eef2f6;border-radius:10px;width:36px;height:36px;cursor:pointer;font-size:20px}.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}.field{display:flex;flex-direction:column;gap:7px}.field.full{grid-column:1/-1}.field label{font-size:12px;font-weight:800;color:#526071}.field input,.field select,.field textarea{border:1px solid var(--border);border-radius:11px;padding:12px}.field textarea{min-height:90px}.amount-box{margin-top:18px;padding:16px;border-radius:14px;background:#eef5fc;display:flex;justify-content:space-between;align-items:center}.amount-box strong{font-size:24px;color:var(--blue)}.notice{padding:13px 15px;border-radius:12px;background:#fff8e8;border:1px solid #f5d98f;color:#805a00;font-size:13px;margin-bottom:16px}
.mobile-top{display:none}
@media(max-width:1050px){.stats{grid-template-columns:repeat(2,1fr)}.two-col{grid-template-columns:1fr}.doc-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:760px){.app{grid-template-columns:1fr}.sidebar{display:none}.main{padding:18px}.mobile-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}.stats,.summary-grid,.doc-grid,.form-grid{grid-template-columns:1fr}.profile-card{grid-template-columns:auto 1fr}.profile-card .btn{grid-column:1/-1}.topbar{flex-direction:column}.table-wrap th,.table-wrap td{white-space:nowrap}}
.stat.clickable{cursor:pointer;transition:.18s}
.stat.clickable:hover{transform:translateY(-3px)}
.login-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.login-choice{padding:28px;text-align:center}
.login-choice h3{margin:10px 0 6px}
.login-choice p{color:var(--muted);font-size:13px;line-height:1.5}
.request-card{padding:18px;margin-bottom:12px}
.request-actions{display:flex;gap:8px;margin-top:12px}
a.btn{text-decoration:none;display:inline-block}
@media(max-width:760px){.login-grid{grid-template-columns:1fr}}
